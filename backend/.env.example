# Copy to .env and fill in values. Do not commit .env.

# Optional: require API key for all /api requests. When set, clients must send X-API-Key or Authorization: Bearer <key>. Leave unset for no auth (e.g. local only). Frontend: set VITE_API_KEY to the same value when building so requests include the key.
# API_KEY=
# BACKEND_API_KEY=

# Transcription engine: api (remote Whisper API, e.g. OpenAI) or faster_whisper (local). Default faster_whisper.
# TRANSCRIBE_ENGINE=api
# TRANSCRIBE_ENGINE=faster_whisper

# Transcription (remote Whisper API, e.g. OpenAI). Optional separate key/base; falls back to OPENAI/GPTS when unset.
# TRANSCRIBE_API_KEY=
# TRANSCRIBE_API_BASE=
# OPENAI_API_KEY=

# Optional: override API base URL for translate/summarize (e.g. proxy or custom endpoint).
# OPENAI_API_BASE=

# Translation. Optional separate key/base; falls back to OPENAI/GPTS when unset. Engine is chosen in UI (API or local).
# TRANSLATE_API_KEY=
# TRANSLATE_API_BASE=
# TRANSLATE_PROVIDER=api

# Summarization (API engine). Defaults to TRANSLATE_API_KEY / OPENAI_API_BASE when unset. Optional separate key/base.
# SUMMARIZE_API_KEY=
# SUMMARIZE_API_BASE=

# Local translation (OPUS-MT): when UI engine is "local", uses these. Models are loaded on first use (e.g. from Hugging Face cache if already downloaded).
# TRANSLATE_OPUS_DEVICE=cpu
# TRANSLATE_OPUS_MODEL_EN_ZH=Helsinki-NLP/opus-mt-en-zh
# TRANSLATE_OPUS_MODEL_ZH_EN=Helsinki-NLP/opus-mt-zh-en

# CORS allowed origins (comma-separated). Default includes localhost:5173, 3000.
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Max audio size for transcribe (default 25MB). Max file upload to server (default 100MB).
# MAX_TRANSCRIBE_BYTES=26214400
# MAX_UPLOAD_BYTES=104857600

# Max concurrent split operations (default 4; set to 1 for serial).
# SPLIT_MAX_CONCURRENT=4

# Max concurrent uploads (default 4; set to 1 for serial). Limits peak memory when reading body.
# UPLOAD_MAX_CONCURRENT=4

# Max concurrent calls to transcription API (Whisper). Respects provider rate/concurrency limits (default 4).
# TRANSCRIBE_MAX_CONCURRENT=4

# faster_whisper only: model (base, small, medium, etc.) and device (cpu, cuda). Defaults: base, cpu.
# FASTER_WHISPER_MODEL=base
# FASTER_WHISPER_DEVICE=cpu
