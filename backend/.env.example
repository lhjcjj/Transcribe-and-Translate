# Copy to .env and fill in values. Do not commit .env.

# Transcription (OpenAI Whisper). Use OPENAI_API_KEY or TRANSCRIBE_API_KEY.
# OPENAI_API_KEY=
# TRANSCRIBE_API_KEY=

# Optional: override API base URL (e.g. proxy or custom endpoint).
# OPENAI_API_BASE=

# Translation. Defaults to OPENAI_API_KEY if not set. Provider: openai (aliyun later).
# TRANSLATE_API_KEY=
# TRANSLATE_PROVIDER=openai

# CORS allowed origins (comma-separated). Default includes localhost:5173, 3000.
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Max audio size for transcribe (default 25MB). Max file upload to server (default 100MB).
# MAX_TRANSCRIBE_BYTES=26214400
# MAX_UPLOAD_BYTES=104857600
